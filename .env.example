# OpenRouter напрямую — вариант до подключения LiteLLM
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-your-openrouter-key
# LLM_MODEL=qwen/qwen3.5-35b-a3b

# Основной режим: приложение обращается к LiteLLM
LLM_BASE_URL=http://localhost:4000/v1
LLM_API_KEY=sk-litellm-virtual-key
# LLM_API_KEY=sk-litellm-low-budget-key
LLM_MODEL=coach-model
LLM_MAX_TOKENS=2048

# Langfuse
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# LiteLLM
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
LITELLM_MASTER_KEY=sk-litellm-master-local-123456789
LITELLM_DATABASE_URL=postgresql://litellm:litellm_password@litellm-postgres:5432/litellm